{
  "name": "is-valid-email",
  "version": "0.1.0",
  "description": "RFC-compliant email address validator with disposable domain detection",
  "repository": "https://github.com/romria/is-valid-email",
  "type": "module",
  "main": "./dist/is-valid-email.js",
  "types": "./dist/is-valid-email.d.ts",
  "exports": {
    ".": {
      "import": "./dist/is-valid-email.js",
      "types": "./dist/is-valid-email.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["email", "validation", "validator", "disposable"],
  "author": "romria",
  "license": "Unlicense",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
